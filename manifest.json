{
  "manifest_version": 3,
  "name": "Agentic Automation",
  "version": "1.0.0",
  "description": "AI-powered browser automation — control tabs, DOM, and network via DeepSeek, OpenAI, or local models",
  "author": "Agentic",
  "minimum_chrome_version": "114",
  "permissions": [
    "debugger",
    "downloads",
    "scripting",
    "tabs",
    "tabGroups",
    "sidePanel",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "settings.html",
  "action": {
    "default_title": "Agentic Automation",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
